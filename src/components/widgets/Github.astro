---
import WidgetWrapper from "./WidgetWrapper.astro";
import Headline from "@/components/ui/Headline.astro";
import Button from "@/components/ui/Button.astro";
import { Icon } from "astro-icon/components";
import type { Widget, CallToAction } from "@/types/types";

export interface Props extends Widget {
  title?: string;
  subtitle?: string;
  tagline?: string;
  icon?: string;
  actions?: string | CallToAction[];
}

const {
  title,
  subtitle,
  tagline,
  icon,
  actions = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render("bg"),
} = Astro.props;

const { container: containerClassProp = "", ...otherClasses } = classes;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`max-w-5xl mx-auto px-4 text-center ${containerClassProp}`}
  bg={bg}
  classes={otherClasses}
>
  <div
    class="py-12 md:py-20 px-8 flex flex-col items-center justify-center rounded-3xl bg-linear-to-br from-indigo-500/5 via-purple-500/5 to-pink-500/5 border border-primary/20 shadow-xl overflow-hidden relative group transition-all duration-300 hover:shadow-2xl hover:border-primary/40"
  >
    <div
      class="absolute inset-0 bg-grid-slate-100/[0.04] bg-[bottom_1px_center] dark:bg-grid-slate-900/[0.04] transition-opacity duration-300 group-hover:opacity-100 opacity-50"
      style="mask-image: linear-gradient(to bottom, transparent, black);"
    >
    </div>
    <div
      class="absolute inset-0 bg-linear-to-b from-transparent to-background/20 z-0"
    >
    </div>
    <div class="relative z-10 flex flex-col items-center justify-center">
      {
        icon && (
          <div class="p-4 bg-background/50 backdrop-blur-sm rounded-2xl mb-6 shadow-sm border border-border/50 group-hover:scale-110 transition-transform duration-300">
            <Icon name={icon} class="w-12 h-12 text-primary" />
          </div>
        )
      }
      <Headline
        title={title}
        subtitle={subtitle}
        tagline={tagline}
        classes={{
          container: "mb-8",
          title: "text-4xl md:text-5xl font-bold tracking-tighter mb-4",
          subtitle:
            "text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto",
        }}
      />

      {
        Array.isArray(actions) && actions.length > 0 && (
          <div class="flex flex-col sm:flex-row gap-4 justify-center w-full sm:w-auto">
            {actions.map((action) => (
              <Button
                href={action.href}
                variant={action.variant as "primary" | "secondary" | "tertiary"}
                aria-label={action.ariaLabel}
                class="w-full sm:w-auto group/btn"
              >
                {action.icon && (
                  <Icon
                    name={action.icon}
                    class="w-5 h-5 mr-2 -ml-1 transition-transform group-hover/btn:-translate-y-0.5"
                  />
                )}
                {action.text}
              </Button>
            ))}
          </div>
        )
      }
    </div>
  </div>
</WidgetWrapper>
