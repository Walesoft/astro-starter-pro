---
import WidgetWrapper from "./WidgetWrapper.astro";
import Headline from "@/components/ui/Headline.astro";
import type { FAQProps } from "@/types/types";
import { Icon } from "astro-icon/components";

const {
  title = await Astro.slots.render("title"),
  subtitle = await Astro.slots.render("subtitle"),
  tagline,
  items = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render("bg"),
  animate = true,
} = Astro.props as FAQProps;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`max-w-6xl mx-auto ${classes?.container ?? ""}`}
  bg={bg}
  animate={animate}
>
  <Headline
    title={title}
    subtitle={subtitle}
    tagline={tagline}
    classes={classes?.headline}
  />

  <div class="grid sm:grid-cols-2 gap-8 md:gap-12 mt-8">
    {
      items &&
        items.map(({ question, answer }) => (
          <div class="flex flex-col">
            <h3 class="mb-3 text-xl font-bold flex items-start">
              <Icon
                name="tabler:chevron-right"
                class="w-6 h-6 text-primary shrink-0 mr-2 mt-0.5"
              />
              {question}
            </h3>
            {answer && (
              <div class="text-muted-foreground ml-8" set:html={answer} />
            )}
          </div>
        ))
    }
  </div>
</WidgetWrapper>
