---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pricing from "@/components/widgets/Pricing.astro";
import Features from "@/components/widgets/Features.astro";
import Values from "@/components/widgets/Values.astro";

const metadata = {
  title: "Pricing - Astro Starter Pro",
  description: "Simple, transparent pricing for teams of all sizes.",
};

const pricingProps = {
  title: "Simple, transparent pricing",
  subtitle: "Choose the plan that fits your needs.",
  tagline: "Pricing",
  plans: [
    {
      name: "Basic",
      price: "$9",
      period: "/month",
      description: "Perfect for personal projects and hobbyists.",
      features: ["1 Project", "Basic Support", "Community Access"],
      buttonText: "Get Started",
      buttonHref: "#",
    },
    {
      name: "Pro",
      price: "$29",
      period: "/month",
      description: "Best for professional developers and small teams.",
      features: [
        "Unlimited Projects",
        "Priority Support",
        "Advanced Analytics",
        "Custom Domains",
      ],
      buttonText: "Upgrade to Pro",
      buttonHref: "#",
      isPopular: true,
    },
    {
      name: "Enterprise",
      price: "$99",
      period: "/month",
      description: "For large organizations with advanced needs.",
      features: [
        "Everything in Pro",
        "24/7 Dedicated Support",
        "SSO Integration",
        "Custom SLAs",
      ],
      buttonText: "Contact Sales",
      buttonHref: "#",
    },
  ],
};

const includedFeatures = {
  title: "Included in all plans",
  subtitle:
    "No matter which plan you choose, you get access to these core features.",
  tagline: "Features",
  features: [
    {
      title: "Global CDN",
      description:
        "Your site is deployed globally for lightning fast load times.",
      icon: "lucide:globe",
      iconClass: "bg-blue-500/10 text-blue-500",
    },
    {
      title: "Auto-scaling",
      description: "We handle traffic spikes automatically without extra cost.",
      icon: "lucide:trending-up",
      iconClass: "bg-green-500/10 text-green-500",
    },
    {
      title: "Secure by default",
      description: "SSL certificates and DDoS protection included.",
      icon: "lucide:shield-check",
      iconClass: "bg-purple-500/10 text-purple-500",
    },
  ],
};

const faqs = {
  title: "Frequently Asked Questions",
  subtitle: "Everything you need to know about our pricing and plans.",
  tagline: "FAQs",
  columns: 2 as const,
  items: [
    {
      title: "Can I switch plans later?",
      description:
        "Absolutely! You can upgrade or downgrade your plan at any time. Prorated charges will be applied automatically.",
      icon: "lucide:help-circle",
    },
    {
      title: "What payment methods do you accept?",
      description:
        "We accept all major credit cards, PayPal, and bank transfers for Enterprise customers.",
      icon: "lucide:credit-card",
    },
    {
      title: "Do you offer a free trial?",
      description:
        "Yes, all our paid plans come with a 14-day free trial so you can test the waters before committing.",
      icon: "lucide:gift",
    },
    {
      title: "Can I cancel my subscription?",
      description:
        "You can cancel your subscription at any time from your billing dashboard. You will continue to have access until the end of your billing period.",
      icon: "lucide:x-circle",
    },
  ],
};
---

<BaseLayout {metadata}>
  <div class="pt-12 md:pt-20">
    <Pricing {...pricingProps} />
  </div>

  <div class="bg-muted/30 py-12">
    <Features {...includedFeatures} />
  </div>

  <div class="py-12 md:py-20">
    <Values {...faqs} />
  </div>
</BaseLayout>
