---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import Content2 from "@/components/widgets/Content2.astro";
import Pricing from "@/components/widgets/Pricing.astro";
import Integrations from "@/components/widgets/Integrations.astro";
import Stats from "@/components/widgets/Stats.astro";
import Testimonials from "@/components/widgets/Testimonials.astro";
import FAQ from "@/components/widgets/FAQ.astro";
import CallToAction from "@/components/widgets/CallToAction.astro";

import devImg from "@/assets/images/dev_balanced.png";
import openSourceImg from "@/assets/images/open-source.png";

const metadata = {
  title: "SaaS Landing Page Template — Astro Starter Pro",
  description:
    "A ready-to-use SaaS landing page showcasing productivity analytics, integrations, and pricing.",
};

const heroProps = {
  title: `Automate Your Workflow with <span class="bg-linear-to-r from-blue-400 via-indigo-400 to-purple-400 bg-clip-text text-transparent">AI Intelligence</span>`,
  tagline: "SaaSFlow AI Platform",
  description:
    "Gain deeper insights, automate repetitive developer tasks, and coordinate team collaborations inside a unified dashboard.",
  actions: [
    {
      text: "Start Free Trial",
      href: "#",
      variant: "primary" as const,
      icon: "lucide:rocket",
    },
    {
      text: "Book a Demo",
      href: "#",
      variant: "secondary" as const,
      icon: "lucide:calendar",
    },
  ],
};

const featuresProps = {
  tagline: "Powerful Capabilities",
  title: "Built for Modern Teams",
  subtitle:
    "Everything you need to ship software faster and monitor operations in real-time.",
  features: [
    {
      title: "Real-time Metrics",
      description:
        "Monitor CPU load, memory consumption, and network usage across all your deployments in a unified live-feed.",
      icon: "lucide:activity",
      iconClass: "bg-blue-500/10 text-blue-400",
    },
    {
      title: "AI Co-pilot Integration",
      description:
        "Automate code reviews, detect security vulnerabilities, and suggest optimizations directly in your pull requests.",
      icon: "lucide:cpu",
      iconClass: "bg-purple-500/10 text-purple-400",
    },
    {
      title: "Global CDN Delivery",
      description:
        "Static and dynamic assets are distributed worldwide instantaneously to deliver sub-millisecond load times.",
      icon: "lucide:globe",
      iconClass: "bg-pink-500/10 text-pink-400",
    },
  ],
};

const pricingProps = {
  title: "Simple, transparent pricing",
  subtitle: "Choose the plan that fits your current operational needs.",
  tagline: "Plans",
  plans: [
    {
      name: "Starter",
      price: "$19",
      period: "/month",
      description: "Ideal for individual developers and side projects.",
      features: [
        "Up to 3 Projects",
        "Basic AI Reviews",
        "10GB Data/Month",
        "Community Forum Access",
      ],
      buttonText: "Start Trial",
      buttonHref: "#",
    },
    {
      name: "Growth",
      price: "$49",
      period: "/month",
      description: "Perfect for scaling startups and small engineering teams.",
      features: [
        "Unlimited Projects",
        "Advanced AI Analysis",
        "100GB Data/Month",
        "Priority Slack Support",
        "Team Management Dashboard",
      ],
      buttonText: "Upgrade to Growth",
      buttonHref: "#",
      isPopular: true,
    },
    {
      name: "Enterprise",
      price: "$149",
      period: "/month",
      description: "Custom capabilities for large organisations.",
      features: [
        "Everything in Growth",
        "Dedicated Server Deployment",
        "Custom AI Fine-tuning",
        "99.9% Uptime SLA",
        "Dedicated Success Manager",
      ],
      buttonText: "Contact Sales",
      buttonHref: "#",
    },
  ],
};

const integrationsProps = {
  title: "Integrate with Your Tech Stack",
  subtitle:
    "SaaSFlow works out-of-the-box with tools you already use every day.",
  tagline: "Integrations",
  integrations: [
    { name: "GitHub", icon: "tabler:brand-github", url: "#" },
    { name: "Slack", icon: "tabler:brand-slack", url: "#" },
    { name: "Vercel", icon: "tabler:brand-vercel", url: "#" },
    { name: "Discord", icon: "tabler:brand-discord", url: "#" },
    { name: "Tailwind CSS", icon: "tabler:brand-tailwind", url: "#" },
    { name: "Supabase", icon: "tabler:brand-supabase", url: "#" },
  ],
};

const statsProps = {
  stats: [
    { title: "Active Users", amount: "10K+", icon: "lucide:users" },
    { title: "Data Processed", amount: "5PB", icon: "lucide:server" },
    { title: "Uptime", amount: "99.9%", icon: "lucide:activity" },
    { title: "Countries", amount: "120", icon: "lucide:globe" },
  ],
};

const testimonialsProps = {
  title: "Trusted by Industry Leaders",
  subtitle: "See what our enterprise customers have to say about SaaSFlow.",
  testimonials: [
    {
      name: "Sarah Jenkins",
      role: "CTO",
      company: "TechNova",
      testimonial:
        "SaaSFlow completely transformed how we manage our deployments. The operational intelligence feature is a game-changer.",
      image:
        "https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80",
    },
    {
      name: "Michael Chen",
      role: "Lead DevOps",
      company: "CloudScale",
      testimonial:
        "The intelligent alerts have saved us from downtime multiple times. Highly recommend for any serious engineering team.",
      image:
        "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80",
    },
    {
      name: "Emily Rodriguez",
      role: "VP Engineering",
      company: "Innovate AI",
      testimonial:
        "Automated PR reviews alone paid for our Growth plan. The AI copilot is surprisingly accurate.",
      image:
        "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80",
    },
  ],
};

const faqProps = {
  title: "Frequently Asked Questions",
  subtitle: "Everything you need to know about the product and billing.",
  items: [
    {
      question: "Is there a free trial available?",
      answer:
        "Yes, we offer a 14-day free trial on all plans. No credit card required.",
    },
    {
      question: "Can I switch plans later?",
      answer:
        "Absolutely. You can upgrade or downgrade your plan at any time. Prorated charges will be applied automatically.",
    },
    {
      question: "Do you offer open-source discounts?",
      answer:
        "Yes! We are proud to support the open-source community. Contact our support team with your project details.",
    },
    {
      question: "What kind of support do you provide?",
      answer:
        "Starter plans get community support. Growth plans get priority Slack support, and Enterprise customers receive a dedicated success manager.",
    },
  ],
};

const ctaProps = {
  title: "Ready to accelerate your delivery?",
  subtitle:
    "Join thousands of developers using SaaSFlow AI to streamline operations and eliminate technical debt today.",
  tagline: "Get Started",
  actions: [
    {
      text: "Create Free Account",
      href: "#",
      variant: "primary" as const,
      icon: "lucide:user-plus",
    },
  ],
};
---

<BaseLayout {metadata}>
  <Hero {...heroProps} />

  <Features {...featuresProps} />

  <Content2
    items={[
      {
        title: "Metrics Dashboard",
        description:
          "Review performance spikes, user activity trends, and API latency graphs all in one place.",
        icon: "lucide:chart-column-increasing",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Intelligent Alerts",
        description:
          "Receive instant notifications via Slack or Discord whenever errors exceed normal thresholds.",
        icon: "lucide:bell",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
    ]}
    image={devImg}
    imageAlt="SaaS Analytics Dashboard mockup"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Operational Intelligence
      </h3>
      Gain absolute visibility into your application stack. Identify performance bottlenecks
      before they affect your end users.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Branch Protection Policies",
        description:
          "Enforce rigorous standards on main branches and automate PR verification seamlessly.",
        icon: "lucide:shield-check",
        iconClass: "bg-indigo-500/10 text-indigo-400",
      },
      {
        title: "Automated Deployments",
        description:
          "Every git commit is built, tested, and deployed to staging environments automatically.",
        icon: "lucide:git-pull-request",
        iconClass: "bg-teal-500/10 text-teal-400",
      },
    ]}
    image={openSourceImg}
    imageAlt="Developer Collaboration tools mockup"
    isReversed={true}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Collaborative Workflows
      </h3>
      Empower your engineering team to collaborate on code features securely and deploy
      updates with absolute confidence.
    </Fragment>
  </Content2>

  <Stats {...statsProps} />

  <Testimonials {...testimonialsProps} />

  <Integrations {...integrationsProps} />

  <Pricing {...pricingProps} />

  <FAQ {...faqProps} />

  <CallToAction {...ctaProps} />
</BaseLayout>
