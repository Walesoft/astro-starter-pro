---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/widgets/Hero.astro";
import Skills from "@/components/widgets/Skills.astro";
import Portfolio from "@/components/widgets/Portfolio.astro";
import Experience from "@/components/widgets/Experience.astro";
import Testimonials from "@/components/widgets/Testimonials.astro";
import CallToAction from "@/components/widgets/CallToAction.astro";

const metadata = {
  title: "Portfolio Template — Astro Starter Pro",
  description:
    "A ready-to-use personal portfolio template to showcase your work, skills, and experience.",
};

const heroProps = {
  title: `Hi, I'm <span class="bg-linear-to-r from-primary to-purple-500 bg-clip-text text-transparent">Alex Developer</span>`,
  tagline: "Software Engineer & UI Designer",
  description:
    "I build fast, responsive, and accessible digital experiences. Currently looking for new opportunities to craft meaningful products.",
  actions: [
    {
      text: "View My Work",
      href: "#portfolio",
      variant: "primary" as const,
      icon: "lucide:briefcase",
    },
    {
      text: "Download Resume",
      href: "#",
      variant: "secondary" as const,
      icon: "lucide:download",
    },
  ],
};

const skillsProps = {
  title: "Tech Stack & Tools",
  subtitle: "Technologies I use on a daily basis to bring ideas to life.",
  tagline: "Skills",
  skills: [
    { name: "Astro", icon: "tabler:brand-astro" },
    { name: "React", icon: "tabler:brand-react" },
    { name: "TypeScript", icon: "tabler:brand-typescript" },
    { name: "Tailwind CSS", icon: "tabler:brand-tailwind" },
    { name: "Node.js", icon: "tabler:brand-nodejs" },
    { name: "Figma", icon: "tabler:brand-figma" },
    { name: "Git", icon: "tabler:brand-git" },
  ],
};

const portfolioProps = {
  id: "portfolio",
  title: "Selected Projects",
  subtitle: "A collection of my recent work in web development and design.",
  tagline: "Portfolio",
  projects: [
    {
      title: "E-Commerce Dashboard",
      description:
        "A complete admin dashboard for tracking sales, managing inventory, and generating analytics reports.",
      image:
        "https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      link: "https://github.com",
      tags: ["React", "Next.js", "Tailwind", "Supabase"],
    },
    {
      title: "FinTech Mobile App",
      description:
        "Cross-platform mobile application for tracking personal expenses and setting budget goals.",
      image:
        "https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      link: "https://github.com",
      tags: ["React Native", "TypeScript", "Firebase"],
    },
    {
      title: "Marketing Landing Page",
      description:
        "High-converting landing page built for a SaaS startup focusing on SEO and performance.",
      image:
        "https://images.unsplash.com/photo-1432888498266-38ffec3eaf0a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      link: "https://github.com",
      tags: ["Astro", "Tailwind CSS", "Framer Motion"],
    },
  ],
};

const experienceProps = {
  title: "Work Experience",
  subtitle: "My professional journey over the past 5 years.",
  tagline: "Experience",
  items: [
    {
      title: "Senior Frontend Engineer",
      company: "TechNova Solutions",
      date: "2021 - Present",
      description:
        "Leading the frontend architecture for the core product. Mentoring junior developers and establishing internal code quality standards.",
      icon: "lucide:briefcase",
    },
    {
      title: "Web Developer",
      company: "Creative Agency X",
      date: "2019 - 2021",
      description:
        "Developed and maintained 20+ client websites using modern headless CMS architectures. Improved average load times by 40%.",
      icon: "lucide:laptop",
    },
    {
      title: "Software Engineering Intern",
      company: "Startup Hub",
      date: "2018 - 2019",
      description:
        "Assisted in building internal tools using React and Node.js. Participated in daily stand-ups and agile sprints.",
      icon: "lucide:graduation-cap",
    },
  ],
};

const testimonialsProps = {
  title: "Recommendations",
  subtitle: "What people I've worked with have to say.",
  tagline: "Testimonials",
  testimonials: [
    {
      name: "Sarah Jenkins",
      role: "CTO",
      company: "TechNova",
      testimonial:
        "SaaSFlow completely transformed how we manage our deployments. The operational intelligence feature is a game-changer.",
      image:
        "https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80",
    },
    {
      name: "Michael Chen",
      role: "Lead DevOps",
      company: "CloudScale",
      testimonial:
        "The intelligent alerts have saved us from downtime multiple times. Highly recommend for any serious engineering team.",
      image:
        "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80",
    },
    {
      name: "Emily Rodriguez",
      role: "VP Engineering",
      company: "Innovate AI",
      testimonial:
        "Automated PR reviews alone paid for our Growth plan. The AI copilot is surprisingly accurate.",
      image:
        "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80",
    },
  ],
};

const ctaProps = {
  title: "Let's work together",
  subtitle:
    "Interested in collaborating or have a project in mind? I'd love to hear from you.",
  tagline: "Contact",
  actions: [
    {
      text: "Send me an Email",
      href: "mailto:hello@example.com",
      variant: "primary" as const,
      icon: "lucide:mail",
    },
    {
      text: "Connect on LinkedIn",
      href: "#",
      variant: "secondary" as const,
      icon: "lucide:linkedin",
    },
  ],
};
---

<BaseLayout {metadata}>
  <Hero {...heroProps} />

  <Skills {...skillsProps} />

  <Portfolio {...portfolioProps} />

  <Experience {...experienceProps} />

  <Testimonials {...testimonialsProps} />

  <CallToAction {...ctaProps} />
</BaseLayout>
